{
  "manifest_version": 3,
  "name": "FocusTab – Animated Productivity New Tab",
  "version": "1.0.0",
  "description": "Replace your new tab with a visually stunning productivity dashboard. Timer runs in the background even when you switch tabs.",

  "permissions": [
    "storage",
    "alarms",
    "offscreen"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "icons": {
    "16":  "icons/icon-16.png",
    "48":  "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },

  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },

  "web_accessible_resources": [
    {
      "resources": ["sounds/complete.mp3", "offscreen.html"],
      "matches":   ["<all_urls>"]
    }
  ]
}